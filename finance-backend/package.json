{
  "name": "finance-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend do projeto Finance",
  "main": "dist/presentation/server.js",
  "scripts": {
    "dev": "tsx --watch src/presentation/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run build && node dist/presentation/server.js",
    "migrate": "tsx src/core/shared/infrastructure/database/run-migrations.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,json,md}\" --check",
    "format:fix": "prettier \"src/**/*.{ts,tsx,js,json,md}\" --write"
  },
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#shared/*": "./dist/core/shared/*",
    "#user/*": "./dist/core/user/*",
    "#category/*": "./dist/core/category/*",
    "#presentation/*": "./dist/presentation/*"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "nodemailer": "^8.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.1.3",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
