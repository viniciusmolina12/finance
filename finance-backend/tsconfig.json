{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node", "jest"],
    "baseUrl": "src",
    "paths": {
      "#shared/*": ["core/shared/*"],
      "#user/*": ["core/user/*"],
      "#category/*": ["core/category/*"],
      "#presentation/*": ["presentation/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
